{
  "name": "@agentic-workflow-kit/eval-kit",
  "version": "0.1.5",
  "description": "Portable eval runner primitives for local eval suites.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.mjs"
  },
  "bin": {
    "eval-kit": "./bin/eval-kit.mjs"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.9.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^26",
      "onFail": "warn"
    }
  },
  "scripts": {
    "dev:setup": "bash scripts/dev-setup.sh",
    "worktree:new": "bash scripts/worktree-new.sh",
    "worktree:clean": "bash scripts/worktree-clean.sh",
    "format": "prettier --write \"**/*.{md,yml,yaml,json,mjs}\"",
    "format:check": "prettier --check \"**/*.{md,yml,yaml,json,mjs}\"",
    "lint": "pnpm format:check",
    "test": "vitest run tests",
    "check": "pnpm lint && pnpm test"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
